#!/usr/bin/env bash

set -euo pipefail

export AWS_VERSION="2.32.7-r0"

export REPOSITORY=aserv92/aws-cli

export PLATFORMS='linux/amd64,linux/arm64'

docker buildx \
  build \
  --push \
  -t "${REPOSITORY}:latest" \
  -t "${REPOSITORY}:${AWS_VERSION}" \
  -t "${REPOSITORY}:${AWS_VERSION}-$(git rev-parse --short HEAD)" \
  --build-arg "AWS_VERSION=${AWS_VERSION}" \
  --platform ${PLATFORMS} \
  .
