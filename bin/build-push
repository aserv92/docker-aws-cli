#!/usr/bin/env bash

set -euo pipefail

BASH_LIBRARIES_DIR='./libraries/bash'

source ./libraries/bash/docker.sh
source ./libraries/bash/docker/alpine.sh
source ./libraries/bash/docker/alpine/apk.sh
source ./libraries/bash/docker/architectures.sh
source ./libraries/bash/docker/registry.sh
source ./libraries/bash/env.sh
source ./libraries/bash/output.sh

output.info "Loading build environment..."
env.load build

output.info "Starting Alpine container..."
docker.alpine.start "$BASE_ALPINE_IMAGE"
set -E
trap 'docker.alpine.remove' ERR

LATEST_ALPINE_VERSION=$(docker.alpine.minor.version)

for TARGET_ARCH in $TARGET_ARCHS; do
  ALPINE_ARCH=${DOCKER_ARCHS_TO_LINUX_ARCHS[$TARGET_ARCH]}
  output.info "Updating $ALPINE_ARCH APK packages..."
  docker.alpine.apk.update "$ALPINE_ARCH"
done

declare -A BUILDS

for TARGET_ARCH in $TARGET_ARCHS; do
  LINUX_ARCH=${DOCKER_ARCHS_TO_LINUX_ARCHS[$TARGET_ARCH]}
  LATEST_AWS_VERSION=$(docker.alpine.apk.query.version "$LINUX_ARCH" aws-cli)
  if [[ $(docker.registry.tag.exists.for.arch "$DOCKER_REGISTRY" "$LATEST_AWS_VERSION" "$TARGET_ARCH") = 'yes' ]]; then
    if [[ "$(docker.run "$DOCKER_REGISTRY:$LATEST_AWS_VERSION" cat /etc/alpine-release | cut -d. -f1,2)" = "$LATEST_ALPINE_VERSION" ]]; then
      output.info "Image with aws-cli($LATEST_AWS_VERSION) with Alpine($LATEST_ALPINE_VERSION) already exists for $TARGET_ARCH. (skipping)"
      continue
    fi
  fi
  output.info "Adding aws-cli version $LATEST_AWS_VERSION ($LINUX_ARCH) to build list."
  BUILDS[$LATEST_AWS_VERSION]+="${BUILDS[$LATEST_AWS_VERSION]:+,}$TARGET_ARCH"
done

for AWS_CLI_VERSION in "${!BUILDS[@]}"; do
  output.info "Building aws-cli version $AWS_CLI_VERSION (${BUILDS[$AWS_CLI_VERSION]})"
  docker buildx build \
    --push \
    -t "${DOCKER_REGISTRY}:latest" \
    -t "${DOCKER_REGISTRY}:${AWS_CLI_VERSION}" \
    -t "${DOCKER_REGISTRY}:${AWS_CLI_VERSION}-$(git rev-parse --short HEAD)" \
    --build-arg "AWS_CLI_VERSION=${AWS_CLI_VERSION}" \
    --build-arg "BASE_ALPINE_IMAGE=${BASE_ALPINE_IMAGE}" \
    --platform "${BUILDS[$AWS_CLI_VERSION]}" \
    .
done

output.info "Removing Alpine container..."
docker.alpine.remove
